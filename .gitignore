# ==========================================
# .gitignore para projetos com n8n
# ==========================================

# 1. Variáveis de Ambiente (Segurança Crítica)
# Garante que senhas, chaves de API e configurações de banco não subam
.env
.env.*

# 2. Pastas do n8n e Banco de Dados Local
# Impede o upload da pasta onde o n8n guarda as credenciais reais e o banco de dados
.n8n/
n8n-data/
*.sqlite
*.db

# 3. Logs de erro
*.log
npm-debug.log*
yarn-debug.log*

# 4. Dependências de pacotes (caso rode scripts Python ou Node.js locais)
node_modules/
__pycache__/
venv/
.venv/

# 5. Arquivos inúteis de Sistema Operacional
.DS_Store
Thumbs.db
desktop.ini
